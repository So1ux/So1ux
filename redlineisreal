local function pressParry()
	keypress(0x46)
	task.wait()
	keyrelease(0x46)
end

local function tryParry(indicator, iaddress)
	-- warn'trying parry'
	if parryActive then
		return
	end

	local now = os_clock() * 1000
	if (now - lastParryTime) < parryConfig.cooldown then
		return
	end

	if parryConfig.maxDist > 0 then
		local char = localPlayer.Character
		local root = char and findFirstChild(char, "HumanoidRootPart")
		if root then
			local dist = (indicator.Position - root.Position).Magnitude
			if dist > parryConfig.maxDist then
				-- warn("too far")
				return
			end
		end
	end

	local glareDelay = glareOffsets[indicator.Name] or 0

	parryActive = true

	task.spawn(function()
		local totalDelay = parryConfig.latency + glareDelay
		if totalDelay > 0 then
			task.wait(totalDelay / 1000)
		end
		keypress(0x46)
		task.wait()
		keyrelease(0x46)
		-- task.wait(0.45)
		local a1 = os_clock()
		parryActive = false
		lastParryTime = os_clock() * 1000
		repeat
			task.wait(0.01)
		until os_clock() - validatedParry < 0.2 or os_clock() - a1 > 0.5

		seenIndicators[iaddress] = nil
		warn("parrydetected")
	end)
end
