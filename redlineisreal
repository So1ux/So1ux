-- Main loop

RunService.RenderStepped:Connect(function()
	if not keyUnlocked then return end

	cleanupLeftPlayers()

	for _, player in ipairs(Players:GetPlayers()) do
		if player.Name == localPlayer.Name then continue end
		local esp = getOrCreateESP(player)
		local label       = esp.label
		local nameLabel   = esp.nameLabel
		local impactLabel = esp.impactLabel

		local character  = player.Character
		local head       = character and character:FindFirstChild("HumanoidRootPart")
		local readOnly   = character and player:FindFirstChild("ReadOnly")
		local healthStat = readOnly  and readOnly:FindFirstChild("health")
		local health     = healthStat and healthStat.Value
		local impactStat = readOnly  and readOnly:FindFirstChild("impact")
		local impact     = impactStat and impactStat.Value

		if not head or not health or health <= 0 then
			label.Visible       = false
			nameLabel.Visible   = false
			impactLabel.Visible = false
			continue
		end

		local headPosition = head.Position + Vector3.new(0, 1.5, 0)
		local screenPos, onScreen = WorldToScreen(headPosition)

		if not onScreen then
			label.Visible       = false
			nameLabel.Visible   = false
			impactLabel.Visible = false
			continue
		end

		label.Outline  = toggles.outline
		label.Size     = sizes.health
		label.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY)
		label.Text     = tostring(health) .. " HP"
		label.Color    = getHealthColor(health)
		label.Visible  = toggles.healthEnabled

		nameLabel.Outline  = toggles.outline
		nameLabel.Size     = sizes.name
		nameLabel.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY - sizes.name - 2)
		nameLabel.Text     = player.Name
		nameLabel.Visible  = toggles.nameEnabled

		local impactRounded = impact and math.floor(impact * 1000 + 0.5) / 1000 or 0
		impactLabel.Outline  = toggles.outline
		impactLabel.Size     = sizes.impact
		impactLabel.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY + sizes.health + 2)
		impactLabel.Text     = "P: " .. string.format("%.3g", impactRounded)
		impactLabel.Visible  = toggles.impactEnabled
	end

	if toggles.autoParry then
		local effects = workspace:FindFirstChild("Effects")

		if effects then
			for _, child in ipairs(effects:GetChildren()) do
				if PARRY_TRIGGERS[child.Name] and child:IsA("BasePart") then
					if not seenIndicators[child.Address] then
						seenIndicators[child.Address] = os.clock()
						warn('attempt parry')
						tryParry(child)
					end
				end
			end
		end
	else
		seenIndicators = {}
		parryActive    = false
	end

end)

while true do
	task.wait(1)
	local t = os.clock()
	for i, v in pairs(seenIndicators) do
		if t - v > 4 then
			seenIndicators[i] = nil
		end
	end
end
