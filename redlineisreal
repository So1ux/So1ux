local last = os_clock()
local offsethead = Vector3.new(0, 2.5, 0)

local d1, d2, d3 = 1000, 0.5, 2 -- pre defining numbers for maximum performance :sob:

-- Main loop

local function rsloop(dt)
	local lpCharacter, lpHrp = getLocalCharacterData()
	for _, player in pairs(getPlayers()) do
		if player.Name == localPlayername then
			continue
		end

		local esp = getOrCreateESP(player)
		local label = esp.label
		local nameLabel = esp.nameLabel
		local impactLabel = esp.impactLabel

		local character = player.Character
		local data = getCachedData(player)
		local targethrp = data.hrp
		local health = data.healthStat and data.healthStat.Value
		local impact = data.impactStat and data.impactStat.Value

		if not targethrp or not health then
			label.Visible = false
			nameLabel.Visible = false
			impactLabel.Visible = false
			continue
		end

		local targethrpPosition = targethrp.Position + offsethead
		local screenPos, onScreen = WorldToScreen(targethrpPosition)

		if not onScreen then
			label.Visible = false
			nameLabel.Visible = false
			impactLabel.Visible = false
			continue
		end

		label.Outline = toggles.outline
		label.Size = sizes.health
		label.Font = currentFont
		label.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY)
		label.Text = tostring(health) .. ad
		label.Color = getHealthColor(health)
		label.Visible = toggles.healthEnabled

		nameLabel.Outline = toggles.outline
		nameLabel.Size = sizes.name
		nameLabel.Font = currentFont
		nameLabel.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY - sizes.name - d3)
		nameLabel.Text = player.Name
		nameLabel.Visible = toggles.nameEnabled

		local impactRounded = impact and math_floor(impact * d1 + d2) / d1 or 0
		impactLabel.Outline = toggles.outline
		impactLabel.Size = sizes.impact
		impactLabel.Font = currentFont
		impactLabel.Position = Vector2.new(screenPos.X, screenPos.Y + CONFIG.OffsetY + sizes.health + d3)
		impactLabel.Text = "" .. string.format("%.3g", impactRounded)
		impactLabel.Visible = toggles.impactEnabled
		local dist
		if CONFIG.MeleeAP then
			dist = getDistance(player, lpHrp, targethrp)

			if dist <= CONFIG.MeleeAPRange then
				local shouldParry = isPlayingSlash(character)
				if shouldParry then
					pressParry()
				end
			end
		end
		if CONFIG.autoattackenabled then
			dist = getDistance(player, lpHrp, targethrp)
			if dist <= CONFIG.autoattackrange then
				local isParrying = isOppParrying(character)
				if isParrying and CONFIG.CancelAuraEnabled then
					warn("continue ")
					continue
				end
				if CONFIG.team_check == true then
					if localPlayerTeam ~= getTeam(player) then
						mouse1click()
					end
				else
					mouse1click()
				end
			end
		end
	end
	if toggles.autoParry then
		if visualEffects then
			for _, child in ipairs(visualEffects:GetChildren()) do
				if PARRY_TRIGGERS[child.Name] then
					-- seenIndicators[child.Address] = os_clock()
					--if not seenIndicators[child.Address] then

					if
						not seenIndicators[tostring(child.Address)]
						and not table.find(seenIndicators, tostring(child.Address))
					then
						seenIndicators[tostring(child.Address)] = os_clock()
						warn(child.Address)
						warn("attempt parry", child.Name)
						tryParry(child, tostring(child.Address))
						--[[
						seenIndicators[child.Address] = os_clock()
						warn('attempt parry', child.Name)
						tryParry(child)
						]]
					end
				end
			end
			for _, child in ipairs(workspEffects:GetChildren()) do
				if child.Name == "defaultParry" then
					local part = nil
					for i, v in pairs(child:GetDescendants()) do
						if v.Name == "SparkDots" then
							part = v.Parent
						end
					end
					if part and part.Position and localPlayer.Character.HumanoidRootPart.Position then
						local distance = (localPlayer.Character.HumanoidRootPart.Position - part.Position).Magnitude

						if distance < 10 then
							if not seenIndicators[part.Address] then
								seenIndicators[part.Address] = true
								validatedParry = os_clock()
								lastParryTime = 0
								if parryActive then
									-- parryActive = false
								end
							end
						end
					end
				end
			end
		end
	else
		table.clear(seenIndicators)
		seenIndicators = {}
		parryActive = false
	end
end

if RunService.RenderStepped then
	RunService.RenderStepped:Connect(function(dt)
		if not keyUnlocked then
			return
		end
		local now = os_clock()
		if now - last >= intervalfps then
			last = now
			cleanupLeftPlayers()
			task.spawn(rsloop, dt)
		end
	end)
else
	task.spawn(function()
		warn("-= MATCHA REDLINER | RenderStepped not detected :sob:, switching to manual loop, 90 FPS UPDATE")
		local FPS = 90
		local INTERVAL = 1 / FPS

		local lastTime = os.clock()
		local lastframestart = os.clock()
		while true do
			warn("fire")
			local now = os.clock()
			local deltaTime = now - lastframestart
			cleanupLeftPlayers()
			task.spawn(rsloop, deltaTime)

			local elapsed = os.clock() - lastTime
			local waitTime = INTERVAL - elapsed

			if waitTime > 0 then
				task.wait(waitTime)
			end
			lastTime = os.clock()
		end
	end)
end

for i, v in pairs(Players:GetPlayers()) do
	onPlayerAdded(v)
end

if Players.PlayerAdded and Players.PlayerRemoving then
	Players.PlayerAdded:Connect(onPlayerAdded)
	Players.PlayerRemoving:Connect(onPlayerRemoving)
else
	warn("-= MATCHA REDLINER | PlayerAdded/Removing missing, falling back to polling =-")
	task.spawn(function()
		while true do
			local current = Players:GetPlayers()
			local currentMap = {}
			for _, p in pairs(current) do
				currentMap[p.Name] = true
				if not playerscache[p.Name] then
					onPlayerAdded(p)
				end
			end
			for name, _ in pairs(playerscache) do
				if not currentMap[name] then
					onPlayerRemoving({ Name = name })
				end
			end
			if Players.PlayerAdded and Players.PlayerRemoving then
				Players.PlayerAdded:Connect(onPlayerAdded)
				Players.PlayerRemoving:Connect(onPlayerRemoving)
				warn("PlayerAdded/Removing support detected, going to connections")
				break
			end
			task.wait(1)
		end
	end)
end
