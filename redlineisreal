local espObjects = {}

local function getHealthColor(health)
	local ratio = math_clamp(health / CONFIG.MaxHealth, 0, 1)
	if ratio > 0.6 then
		return CONFIG.HealthColors.High
	elseif ratio > 0.3 then
		return CONFIG.HealthColors.Medium
	else
		return CONFIG.HealthColors.Low
	end
end

local function getOrCreateESP(player)
	if not espObjects[player.Name] then
		local label = Drawing.new("Text")
		label.Visible = true
		label.Center = true
		label.Outline = toggles.outline
		label.Size = sizes.health

		local nameLabel = Drawing.new("Text")
		nameLabel.Visible = true
		nameLabel.Center = true
		nameLabel.Outline = toggles.outline
