-- ESP

local espObjects = {}

local function getHealthColor(health)
	local ratio = math_clamp(health / CONFIG.MaxHealth, 0, 1)
	if ratio > 0.6 then
		return CONFIG.HealthColors.High
	elseif ratio > 0.3 then
		return CONFIG.HealthColors.Medium
	else
		return CONFIG.HealthColors.Low
	end
end

local function getOrCreateESP(player)
	if not espObjects[player.Name] then
		local label = Drawing.new("Text")
		label.Visible = true
		label.Center  = true
		label.Outline = toggles.outline
		label.Size    = sizes.health

		local nameLabel = Drawing.new("Text")
		nameLabel.Visible = true
		nameLabel.Center  = true
		nameLabel.Outline = toggles.outline
		nameLabel.Size    = sizes.name
		nameLabel.Color   = Color3.fromRGB(255, 255, 255)

		local impactLabel = Drawing.new("Text")
		impactLabel.Visible = true
		impactLabel.Center  = true
		impactLabel.Outline = toggles.outline
		impactLabel.Size    = sizes.impact
		impactLabel.Color   = Color3.fromRGB(180, 140, 255)

		espObjects[player.Name] = { label = label, nameLabel = nameLabel, impactLabel = impactLabel }
	end
	return espObjects[player.Name]
end

local function cleanupLeftPlayers()
	local currentPlayers = Players:GetPlayers()
	local playerSet = {}
	for _, p in ipairs(currentPlayers) do
		playerSet[p.Name] = true
	end
	for player, esp in pairs(espObjects) do
		if not playerSet[player] then
			esp.label:Remove()
			esp.nameLabel:Remove()
			esp.impactLabel:Remove()
			espObjects[player] = nil
		end
	end
end

local function getDistance(otherPlayer)
	local char1 = localPlayer.Character
	local char2 = otherPlayer.Character
	if not char1 or not char2 then return math_huge end

	local root1 = char1:FindFirstChild("HumanoidRootPart")
	local root2 = char2:FindFirstChild("HumanoidRootPart")
	if not root1 or not root2 then return math_huge end

	return (root1.Position - root2.Position).Magnitude
end

-- Add near the top, after espObjects is declared
function refreshAllDrawings()
	for _, esp in pairs(espObjects) do
		pcall(function() esp.label:Remove() end)
		pcall(function() esp.nameLabel:Remove() end)
		pcall(function() esp.impactLabel:Remove() end)
	end
	espObjects = {}
	warn("Drawings refreshed")
end

local function getuserid(player)
	local id = -1
	if cacheduserids[player.Name] then
		return cacheduserids[player.Name]
	else
		id = memory_read("int", player.Address + 760)
		cacheduserids[player.Name] = id
	end
	
	
	return id 
end

local function getTeam(player)
	local teamId = -1
	if not rs.ReadOnly.Match:FindFirstChild("Players") then
		return teamId
	end
	if not player then 
		return teamId
	end
	local team = rs.ReadOnly.Match.Players:FindFirstChild(getuserid(player))
	if team then
		team = team:GetAttribute("team_id")
	end
	teamId = team or teamId
	return teamId
end

