-- ESP

local espObjects = {}

local function getHealthColor(health)
	local ratio = math.clamp(health / CONFIG.MaxHealth, 0, 1)
	if ratio > 0.6 then
		return CONFIG.HealthColors.High
	elseif ratio > 0.3 then
		return CONFIG.HealthColors.Medium
	else
		return CONFIG.HealthColors.Low
	end
end

local function getOrCreateESP(player)
	if not espObjects[player.Name] then
		local label = Drawing.new("Text")
		label.Visible = true
		label.Center  = true
		label.Outline = toggles.outline
		label.Size    = sizes.health

		local nameLabel = Drawing.new("Text")
		nameLabel.Visible = true
		nameLabel.Center  = true
		nameLabel.Outline = toggles.outline
		nameLabel.Size    = sizes.name
		nameLabel.Color   = Color3.fromRGB(255, 255, 255)

		local impactLabel = Drawing.new("Text")
		impactLabel.Visible = true
		impactLabel.Center  = true
		impactLabel.Outline = toggles.outline
		impactLabel.Size    = sizes.impact
		impactLabel.Color   = Color3.fromRGB(180, 140, 255)

		espObjects[player.Name] = { label = label, nameLabel = nameLabel, impactLabel = impactLabel }
	end
	return espObjects[player.Name]
end

local function cleanupLeftPlayers()
	local currentPlayers = Players:GetPlayers()
	local playerSet = {}
	for _, p in ipairs(currentPlayers) do
		playerSet[p] = true
	end
	for player, esp in pairs(espObjects) do
		if not playerSet[player] then
			esp.label:Remove()
			esp.nameLabel:Remove()
			esp.impactLabel:Remove()
			espObjects[player] = nil
		end
	end
end

-- Auto Parry

local parryActive     = false
local lastParryTime   = 0
local seenIndicators  = {}

local PARRY_TRIGGERS = {
	-- ["ParryIndicator"] = true,
	-- ["CastigateFlash"] = true,
	["SuspendedIndicator"] = true,
}

local function tryParry(indicator)
	warn'trying parry'
	if parryActive then return end

	local now = os.clock() * 1000
	if (now - lastParryTime) < parryConfig.cooldown then return end

	if parryConfig.maxDist > 0 then
		local char = localPlayer.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if root then
			local dist = (indicator.Position - root.Position).Magnitude
			if dist > parryConfig.maxDist then warn'too far' return end
		end
	end

	local flashDelay = flashOffsets[indicator.Name] or 0

	parryActive   = true
	lastParryTime = os.clock() * 1000
	task.spawn(function()
		local totalDelay = parryConfig.latency + flashDelay
		if totalDelay > 0 then
			task.wait(totalDelay / 1000)
		end
		keypress(0x46)
		task.wait(0.1)
		keyrelease(0x46)
		parryActive = false
	end)
end

