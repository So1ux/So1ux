local function getCachedData(player)
	local character = player.Character
	local data = PlayerCacheParts[player.Name]

	-- if no cache yet, or character changed (respawn), rebuild it
	if not data or data.character ~= character then
		data = { character = character }
		PlayerCacheParts[player.Name] = data

		if character then
			data.hrp = findFirstChild(character, "HumanoidRootPart")
		end

		local readOnly = findFirstChild(player, "ReadOnly")
		if readOnly then
			data.readOnly = readOnly
			data.healthStat = findFirstChild(readOnly, "health")
			data.impactStat = findFirstChild(readOnly, "impact")
		end
	end

	return data
end

