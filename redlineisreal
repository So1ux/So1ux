local function cleanupLeftPlayers()
	local currentPlayers = getPlayers()
	local playerSet = {}
	for _, p in pairs(currentPlayers) do
		playerSet[p.Name] = true
	end
	for player, esp in pairs(espObjects) do
		if not playerSet[player] then
			esp.label:Remove()
			esp.nameLabel:Remove()
			esp.impactLabel:Remove()
			espObjects[player] = nil
		end
	end
end

local function getDistance(otherPlayer, root1, root2)
	local char1 = localPlayer.Character
	local char2 = otherPlayer.Character
	if not char1 or not char2 then
		return math_huge
	end

	local root1 = root1 -- findFirstChild(char1, "HumanoidRootPart")
	local root2 = root2
	if not root1 or not root2 then
		return math_huge
	end

	return (root1.Position - root2.Position).Magnitude
end

