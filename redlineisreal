local function getTeam(player)
	local teamId = -1
	if not rs.ReadOnly.Match:FindFirstChild("Players") then
		return teamId
	end
	if not player then
		return teamId
	end
	local team = rs.ReadOnly.Match.Players:FindFirstChild(getuserid(player))
	if team then
		team = team:GetAttribute("team_id")
	end
	teamId = team or teamId
	return teamId
end

local function isSameAnim(v)
	if not timePosOfLastHit or v.id ~= timePosOfLastHit.id then
		return false
	end

	timePosOfLastHit = { uhh = os.clock(), timepos = v.timePos, id = v.id }
	local elapsed = os.clock() - timePosOfLastHit.uhh
	local delta = v.timePos - timePosOfLastHit.timepos

	-- if timePos advanced roughly in line with real time, it's still the same ongoing swing
	return math.abs(delta - elapsed) < 0.2
end

local function isPlayingSlash(character)
	local data = animReader(character)
	for i, v in pairs(data) do
		if table.find(MeleeAP_Triggers, v.id) then
			if v.timePos > 0.4 then
				continue
			end
			if isSameAnim(v) then
				continue -- same swing still playing, ignore
			end
			return true
		end
	end

	return false
end
